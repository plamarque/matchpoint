# URL WebSocket du backend de télécommande (Cloud Run ou local).
# Vide ou absent = télécommande désactivée (message « indisponible sans Internet »).
# Ex. en local : ws://localhost:8080
# Ex. Cloud Run : wss://matchpoint-remote-XXXXX-xx.a.run.app
VITE_REMOTE_BACKEND_WS_URL=

# Origine publique de la PWA (pour le lien du QR code).
# Optionnel : par défaut = origin + base path au moment du build.
# VITE_REMOTE_CONTROL_ORIGIN=https://votre-utilisateur.github.io/matchpoint
